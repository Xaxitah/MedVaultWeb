          {
            "name": "Tolerância: Intervalo livre de 8-12h"
          },
          {
            "name": "Efeitos: Cefaleia pulsátil e hipotensão"
          }
        ]
      },
      {
        "name": "Nitroprussiato de Sódio",
        "children": [
