{
  "mind_map": {
    "name": "Inotrópicos Positivos",
    "children": [
      {
        "name": "Visão Geral",
        "children": [
          {
            "name": "Objetivo: Aumento da força de contração"
          },
          {
            "name": "Indicações: IC aguda, Choque cardiogênico"
          },
          {
            "name": "Conceitos: Pré-carga, Pós-carga, Fração de ejeção"
          }
        ]
      },
      {
        "name": "Digitálicos (Digoxina)",
        "children": [
          {
            "name": "Mecanismo: Inibição da Na+/K+-ATPase"
          },
          {
            "name": "Efeitos: Inotropismo (+), Cronotropismo (-), Dromotropismo (-)"
          },
          {
            "name": "Farmacocinética: Eliminação renal, t½ 36-48h"
          },
          {
            "name": "Toxicidade: Estreita margem, Hipopotassemia aumenta risco"
          },
          {
            "name": "Sintomas Tóxicos: Náuseas, Arritmias, Visão borrada/amarelada"
          },
          {
            "name": "Antídoto: Digibind (Fab antidigoxina)"
          }
        ]
      },
      {
        "name": "Simpatomiméticos",
        "children": [
          {
            "name": "Dopamina",
            "children": [
              {
                "name": "Dose Baixa: D1/D2 (Vasodilatação renal)"
              },
              {
                "name": "Dose Média: β1 (Inotropismo)"
              },
              {
                "name": "Dose Alta: α1 (Vasoconstrição)"
              }
            ]
          },
          {
            "name": "Dobutamina",
            "children": [
              {
                "name": "Predomínio β1"
              },
              {
                "name": "Menos taquiarritmias que dopamina"
              },
              {
                "name": "Uso em IC + Coronariopatia"
              }
            ]
          }
        ]
      },
      {
        "name": "Inibidores da PDE III",
        "children": [
          {
            "name": "Fármacos: Milrinona, Amrinona"
          },
          {
            "name": "Mecanismo: ↑ AMPc e ↑ Ca2+"
          },
          {
            "name": "Efeito Inodilatador: ↑ Débito e ↓ Pós-carga"
          },
          {
            "name": "Diferença: Amrinona causa trombocitopenia"
          }
        ]
      },
      {
        "name": "Sensibilizadores de Cálcio",
        "children": [
          {
            "name": "Fármacos: Levosimendan, Pimobendan"
          },
          {
            "name": "Mecanismo: Sensibiliza Troponina C ao Ca2+"
          },
          {
            "name": "Vantagem: Menor risco de arritmias"
          },
          {
            "name": "Ação extra: Vasodilatação (canais K+ ATP)"
          }
        ]
      }
    ]
  },
